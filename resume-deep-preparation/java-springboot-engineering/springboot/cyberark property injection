## Complete Example Implementation

Here's a complete, working example that demonstrates all concepts:

```java
// 1. CyberArk Service Layer
@Service
public class CyberArkService {
    private final CyberArkClient client;
    
    @Autowired
    public CyberArkService(CyberArkClient client) {
        this.client = client;
    }
    
    public Map<String, String> retrieveSecrets(List<String> secretIds) {
        Map<String, String> secrets = new HashMap<>();
        for (String id : secretIds) {
            Credential cred = client.retrieve(id);
            secrets.put(cred.getPropertyKey(), cred.getValue());
        }
        return secrets;
    }
    
    public Supplier<String> getCredentialSupplier(String secretId) {
        return () -> {
            Credential cred = client.retrieve(secretId);
            return cred.getValue();
        };
    }
}

// 2. Property Loader (Adapter + Orchestrator)
@Component
public class CyberArkPropertyLoader {
    
    @Autowired
    private ConfigurableEnvironment environment;
    
    @Autowired
    private CyberArkService cyberArkService;
    
    @Value("${cyberark.secret.ids:}")  // Comma-separated list
    private String secretIds;
    
    @PostConstruct
    public void loadSecrets() {
        try {
            // Parse secret IDs
            List<String> ids = Arrays.asList(secretIds.split(","));
            
            // Retrieve secrets from CyberArk
            Map<String, String> secrets = cyberArkService.retrieveSecrets(ids);
            
            // Convert to PropertySource (Adapter Pattern)
            MapPropertySource propertySource = new MapPropertySource(
                "cyberark-secrets", 
                new HashMap<>(secrets)
            );
            
            // Add to Environment with highest priority
            environment.getPropertySources().addFirst(propertySource);
            
            logger.info("Loaded {} secrets from CyberArk", secrets.size());
        } catch (Exception e) {
            logger.error("Failed to load CyberArk secrets", e);
            throw new RuntimeException("CyberArk initialization failed", e);
        }
    }
}

